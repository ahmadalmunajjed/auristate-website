---
import Layout from '../../layouts/Layout.astro';

const nav = ['Home', 'About', 'Projects', 'Blog', 'Contact'];

const stats = [
	{ value: '12+', label: 'Years Regional Expertise' },
	{ value: '$150M+', label: 'Under Development' },
	{ value: '8', label: 'Active Projects' },
	{ value: '3', label: 'Cities' }
];

const projects = [
	{ name: 'Latakia Coastal Residences', tag: 'Coastal / Residential', image: '/images/projects/latakia-coastal.jpg' },
	{ name: 'Old Damascus Quarter Restoration', tag: 'Heritage / Mixed-Use', image: '/images/projects/old-damascus.jpg' },
	{ name: 'Palmyra Heritage Resort', tag: 'Hospitality / Resort', image: '/images/projects/palmyra-resort.jpg' }
];

const posts = [
	{ title: "Why Syria's Coastline Is Emerging for Tourism Investment", date: 'Jun 2026' },
	{ title: 'A Guide to Real Estate Regulations for Foreign Investors', date: 'May 2026' },
	{ title: 'Inside Our Latest Development: Latakia Coastal Residences', date: 'Apr 2026' }
];
---

<Layout title="Auristate — Concept B: Bold Editorial Dark" fonts={['--font-display-b', '--font-body-b']}>
	<div class="bg-nearblack text-offwhite" style="font-family: var(--font-body-b);">
		<!-- Header -->
		<header class="absolute inset-x-0 top-0 z-10">
			<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
				<div class="rounded-full bg-offwhite px-4 py-2 shadow-lg">
					<img src="/logo.jpeg" alt="Auristate" class="h-9 w-auto mix-blend-multiply" />
				</div>
				<nav class="hidden items-center gap-8 md:flex">
					{
						nav.map((item) => (
							<a href="#" class="text-sm tracking-wide text-offwhite/80 transition hover:text-gold-light">
								{item}
							</a>
						))
					}
				</nav>
				<div class="flex items-center gap-1 rounded-full border border-gold/40 px-3 py-1.5 text-xs tracking-widest">
					<span class="font-semibold text-gold-light">EN</span>
					<span class="text-offwhite/30">/</span>
					<a href="#" class="text-offwhite/60 hover:text-gold-light">AR</a>
				</div>
			</div>
		</header>

		<!-- Hero -->
		<section class="relative overflow-hidden">
			<div
				class="animate-float pointer-events-none absolute -right-20 -top-10 h-[32rem] w-[32rem] opacity-90 [clip-path:polygon(50%_0%,0%_100%,100%_100%)]"
				style="background: linear-gradient(140deg, var(--color-gold-light), var(--color-gold-dark) 60%, var(--color-charcoal));"
			>
			</div>
			<div
				class="animate-float pointer-events-none absolute right-24 top-64 h-56 w-56 opacity-60 [clip-path:polygon(50%_0%,0%_100%,100%_100%)]"
				style="background: linear-gradient(140deg, var(--color-grey-light), var(--color-charcoal)); animation-delay: 1.8s;"
			>
			</div>
			<div class="relative mx-auto max-w-6xl px-6 pb-28 pt-48 md:pt-56">
				<p class="animate-hero mb-6 text-xs tracking-[0.4em] text-gold-light uppercase" style="animation-delay: 0ms;">Tourism &amp; Real Estate Investment</p>
				<h1 class="animate-hero max-w-3xl text-6xl leading-[1.05] text-offwhite md:text-7xl" style="font-family: var(--font-display-b); font-weight: 700; animation-delay: 140ms;">
					Building Syria's <span class="text-gold-light italic">Next Chapter</span>
				</h1>
				<p class="animate-hero mt-8 max-w-xl text-lg text-offwhite/70" style="animation-delay: 320ms;">
					Auristate identifies, develops, and manages premium tourism and real estate investments across Syria's
					coast, historic cities, and emerging regions.
				</p>
				<div class="animate-hero mt-10 flex flex-wrap items-center gap-5" style="animation-delay: 460ms;">
					<a href="#" class="bg-gold px-8 py-3.5 text-sm font-semibold tracking-wide text-nearblack transition hover:bg-gold-light">
						Explore Our Projects
					</a>
					<a href="#" class="border border-offwhite/30 px-8 py-3.5 text-sm tracking-wide text-offwhite transition hover:border-gold-light hover:text-gold-light">
						Get in Touch
					</a>
				</div>
			</div>
		</section>

		<!-- About teaser -->
		<section class="bg-charcoal py-24">
			<div class="mx-auto max-w-6xl px-6">
				<div class="grid gap-16 md:grid-cols-2">
					<div class="reveal">
						<p class="mb-4 text-xs tracking-[0.4em] text-gold-light uppercase">About Auristate</p>
						<h2 class="mb-6 text-4xl text-offwhite" style="font-family: var(--font-display-b); font-weight: 700;">
							Unlocking Syria's Potential
						</h2>
						<p class="leading-relaxed text-offwhite/70">
							Auristate is a tourism and real estate investment firm dedicated to unlocking Syria's potential —
							from coastal resorts to heritage restorations. We partner with investors and communities to build
							lasting value.
						</p>
					</div>
					<div class="grid grid-cols-2 gap-8">
						{
							stats.map((stat, i) => (
								<div class="reveal" style={`--reveal-delay: ${i * 100}ms`}>
									<p class="text-4xl text-gold-light" style="font-family: var(--font-display-b); font-weight: 700;">
										{stat.value}
									</p>
									<p class="mt-2 text-xs tracking-widest text-offwhite/50 uppercase">{stat.label}</p>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<!-- Featured projects -->
		<section class="py-24">
			<div class="mx-auto max-w-6xl px-6">
				<div class="reveal mb-14 flex items-end justify-between">
					<div>
						<p class="mb-4 text-xs tracking-[0.4em] text-gold-light uppercase">Featured Projects</p>
						<h2 class="text-4xl text-offwhite" style="font-family: var(--font-display-b); font-weight: 700;">
							Selected Developments
						</h2>
					</div>
					<a href="#" class="hidden text-sm text-offwhite/60 hover:text-gold-light md:block">View All Projects</a>
				</div>
				<div class="grid gap-8 md:grid-cols-3">
					{
						projects.map((project, i) => (
							<a href="#" class="reveal group block border border-offwhite/10 p-1 transition hover:border-gold/60" style={`--reveal-delay: ${i * 120}ms`}>
								<div class="aspect-[4/3] overflow-hidden">
									<img
										src={project.image}
										alt={project.name}
										class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
									/>
								</div>
								<div class="p-5">
									<p class="mb-2 text-xs tracking-widest text-gold-light uppercase">{project.tag}</p>
									<h3 class="text-xl text-offwhite" style="font-family: var(--font-display-b); font-weight: 600;">
										{project.name}
									</h3>
									<span class="mt-3 inline-block text-sm text-offwhite/50 group-hover:text-gold-light">View Project →</span>
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<!-- Blog teaser -->
		<section class="bg-charcoal py-24">
			<div class="mx-auto max-w-6xl px-6">
				<p class="mb-4 text-xs tracking-[0.4em] text-gold-light uppercase">From the Journal</p>
				<h2 class="mb-14 text-4xl text-offwhite" style="font-family: var(--font-display-b); font-weight: 700;">
					Insights &amp; Updates
				</h2>
				<div class="grid gap-10 md:grid-cols-3">
					{
						posts.map((post, i) => (
							<a href="#" class="reveal group block border-t-2 border-gold/40 pt-6" style={`--reveal-delay: ${i * 120}ms`}>
								<p class="mb-3 text-xs text-offwhite/40">{post.date}</p>
								<h3 class="text-lg leading-snug text-offwhite group-hover:text-gold-light" style="font-family: var(--font-display-b); font-weight: 600;">
									{post.title}
								</h3>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<!-- CTA band -->
		<section class="bg-gold py-20">
			<div class="reveal mx-auto max-w-3xl px-6 text-center">
				<h2 class="mb-6 text-4xl text-nearblack" style="font-family: var(--font-display-b); font-weight: 700;">
					Ready to Invest in Syria's Future?
				</h2>
				<a href="#" class="inline-block bg-nearblack px-8 py-3.5 text-sm font-semibold tracking-wide text-gold-light transition hover:bg-charcoal">
					Contact Our Team
				</a>
			</div>
		</section>

		<!-- Footer -->
		<footer class="px-6 py-16">
			<div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-4">
				<div>
					<div class="mb-4 inline-block rounded-full bg-offwhite px-4 py-2">
						<img src="/logo.jpeg" alt="Auristate" class="h-8 w-auto mix-blend-multiply" />
					</div>
					<p class="text-sm text-offwhite/50">Tourism &amp; real estate investment across Syria.</p>
				</div>
				<div>
					<p class="mb-4 text-xs tracking-widest text-gold-light uppercase">Navigate</p>
					<ul class="space-y-2 text-sm text-offwhite/60">
						{nav.map((item) => <li><a href="#" class="hover:text-gold-light">{item}</a></li>)}
					</ul>
				</div>
				<div>
					<p class="mb-4 text-xs tracking-widest text-gold-light uppercase">Contact</p>
					<ul class="space-y-2 text-sm text-offwhite/60">
						<li>info@auristate.com</li>
						<li>+963 00 000 0000</li>
						<li>Damascus, Syria</li>
					</ul>
				</div>
				<div>
					<p class="mb-4 text-xs tracking-widest text-gold-light uppercase">Follow</p>
					<ul class="space-y-2 text-sm text-offwhite/60">
						<li><a href="#" class="hover:text-gold-light">LinkedIn</a></li>
						<li><a href="#" class="hover:text-gold-light">Instagram</a></li>
					</ul>
				</div>
			</div>
			<div class="mx-auto mt-14 max-w-6xl border-t border-offwhite/10 pt-6 text-xs text-offwhite/30">
				© 2026 Auristate. All rights reserved.
			</div>
		</footer>
	</div>
</Layout>

<script>
	import '../../scripts/reveal.js';
</script>
